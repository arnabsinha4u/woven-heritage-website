---
import { getCollection } from "astro:content";
import ProductCard from "../components/ProductCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import StitchedImageCard from "../components/StitchedImageCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeContent, site } from "../data/site";
import "../styles/global.css";

const products = await getCollection("products");
const featuredProducts = homeContent.featuredSlugs
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);
---

<BaseLayout title={site.name}>
  <SiteHeader />

  <main>
    <section class="page-shell grid gap-12 py-12 md:grid-cols-[minmax(0,1fr)_minmax(320px,34rem)] md:items-center md:py-20">
      <div class="space-y-8">
        <p class="section-kicker">{homeContent.kicker}</p>
        <div class="space-y-6">
          <h1 class="font-headline text-5xl leading-[1.05] text-on-surface sm:text-6xl lg:text-7xl">
            Threads of <span class="italic text-primary-container">{homeContent.highlight}</span> Wisdom
          </h1>
          <p class="max-w-xl text-lg leading-8 text-on-surface-variant sm:text-xl">{homeContent.intro}</p>
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="/collection" class="cta-primary">Explore the Collection</a>
          <a href="#story" class="cta-tertiary">Our Lineage</a>
        </div>
      </div>

      <StitchedImageCard
        src="/images/editorial/grandmother-lesson.jpg"
        alt="Tender portrait of an elder teaching the next generation how to crochet in a warm living room."
        note={homeContent.heroQuote}
        attribution={homeContent.heroAttribution}
      />
    </section>

    <section id="story" class="bg-surface-low py-20">
      <div class="page-shell grid gap-12 md:grid-cols-[minmax(280px,28rem)_minmax(0,1fr)] md:items-center">
        <div class="relative">
          <div class="stitched-frame">
            <img
              src="/images/editorial/terracotta-hands.jpg"
              alt="Close-up of weathered hands working with terracotta yarn and a vintage wooden hook."
              class="aspect-square h-full w-full object-cover"
              loading="lazy"
              data-image-slot="story"
            />
          </div>
          <div class="absolute -bottom-4 -right-2 rounded-full bg-primary p-4 text-on-primary shadow-float sm:-bottom-6 sm:-right-4">
            <span class="text-xl">✦</span>
          </div>
        </div>

        <div class="space-y-8">
          <SectionHeading title={homeContent.storyTitle} />

          <div class="space-y-6">
            {homeContent.storyParagraphs.map((paragraph) => (
              <p class="content-copy">{paragraph}</p>
            ))}
          </div>

          <div class="flex flex-wrap gap-10 pt-2">
            {homeContent.stats.map((stat) => (
              <div>
                <p class="font-headline text-4xl text-primary">{stat.value}</p>
                <p class="mt-2 text-xs font-semibold uppercase tracking-[0.22em] text-on-surface-variant">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="page-shell py-20">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          title={homeContent.featuredTitle}
          description={homeContent.featuredDescription}
        />
        <a href="/collection" class="cta-tertiary">View Entire Archive</a>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {featuredProducts.map((product, index) => (
          <div class:list={[index === 1 && "lg:translate-y-10"]}>
            <ProductCard product={product!} />
          </div>
        ))}
      </div>
    </section>

    <section id="process" class="px-4 pb-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-editorial overflow-hidden rounded-[2.8rem] bg-surface-high py-16 sm:px-6 lg:px-10">
        <div class="page-shell">
          <div class="mx-auto max-w-3xl text-center">
            <p class="section-kicker">Process</p>
            <h2 class="mt-5 font-headline text-4xl text-on-surface sm:text-5xl">{homeContent.processTitle}</h2>
            <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-on-surface-variant">{homeContent.processDescription}</p>
          </div>

          <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {homeContent.processSteps.map((item) => (
              <div class="rounded-lounge bg-white/65 px-5 py-6 text-center shadow-ambient">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">{item.label}</p>
                <p class="mt-3 text-sm leading-6 text-on-surface-variant">{item.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
