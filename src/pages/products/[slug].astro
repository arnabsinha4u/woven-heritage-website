---
import { getCollection } from "astro:content";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ValuesBento from "../../components/ValuesBento.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const secondaryImage = product.data.gallery.find((image) => image.slot === 2);
const archiveImage = product.data.gallery.find((image) => image.slot === 3);
---

<BaseLayout title={product.data.title}>
  <SiteHeader />

  <main class="page-shell py-12 sm:py-16">
    <section class="grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:items-start">
      <div class="relative">
        <div class="stitched-frame">
          <img
            src={product.data.hero_image}
            alt={product.data.alt}
            class="aspect-[4/5] h-full w-full object-cover md:aspect-square"
            loading="eager"
            data-product-id={product.data.id}
            data-product-slug={product.slug}
            data-image-slot="1"
            data-collection-name={product.data.list_name}
          />
        </div>

        {product.data.quote && (
          <div class="absolute -bottom-6 right-4 hidden max-w-xs rounded-lounge bg-surface-highest/95 p-6 shadow-float ghost-outline lg:block">
            <p class="font-headline text-lg italic leading-7 text-primary">{product.data.quote}</p>
          </div>
        )}
      </div>

      <div class="space-y-8" data-product-id={product.data.id} data-product-slug={product.slug}>
        <nav class="text-xs font-semibold uppercase tracking-[0.22em] text-on-surface-variant">
          <a href="/collection" class="transition-colors hover:text-primary">Collection</a>
          <span class="mx-2">/</span>
          <span>{product.data.collection}</span>
        </nav>

        <div class="space-y-4">
          <h1 class="font-headline text-5xl leading-tight text-on-surface sm:text-6xl">{product.data.title}</h1>
          <p class="text-lg text-primary sm:text-xl">{product.data.subtitle}</p>
        </div>

        <div class="soft-panel p-6">
          <p class="section-kicker">Archive Notes</p>
          <p class="mt-4 text-base leading-7 text-on-surface-variant">{product.data.archive_note}</p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-white/65 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Collection</p>
              <p class="mt-2 text-sm leading-6 text-on-surface-variant">{product.data.collection}</p>
            </div>
            <div class="rounded-2xl bg-white/65 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Making Window</p>
              <p class="mt-2 text-sm leading-6 text-on-surface-variant">{product.data.making_window}</p>
            </div>
          </div>
        </div>

        <div class="space-y-5">
          <p class="text-lg leading-8 text-on-surface-variant">{product.data.summary}</p>
          <div class="flex flex-wrap gap-3">
            {product.data.materials.map((material) => (
              <span class="chip bg-secondary-container/90">{material}</span>
            ))}
          </div>
        </div>

        {product.data.story.length > 0 && (
          <div class="space-y-4">
            <p class="section-kicker">Story</p>
            <div class="space-y-5">
              {product.data.story.map((paragraph) => (
                <p class="content-copy">{paragraph}</p>
              ))}
            </div>
          </div>
        )}

        <div class="flex flex-wrap gap-4">
          <a href="/collection" class="cta-primary">Browse the Collection</a>
          <a href="/#process" class="cta-secondary">Read the Process</a>
        </div>
      </div>
    </section>

    <section class="mt-20 grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center">
      <div class="space-y-6">
        <p class="section-kicker">Technique</p>
        <h2 class="font-headline text-4xl text-on-surface sm:text-5xl">The Technique</h2>
        <div class="space-y-5">
          {product.data.technique.map((paragraph) => (
            <p class="content-copy">{paragraph}</p>
          ))}
        </div>

        {product.data.artisans && (
          <div class="pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary">Artisans</p>
            <div class="mt-5 flex flex-wrap items-center gap-4">
              {product.data.artisans.map((artisan) => (
                <div class="flex items-center gap-3 rounded-full bg-surface-low px-3 py-2">
                  <img
                    src={artisan.image}
                    alt={artisan.alt}
                    class="h-11 w-11 rounded-full object-cover"
                    loading="lazy"
                    data-image-slot="artisan"
                    data-product-id={product.data.id}
                    data-product-slug={product.slug}
                  />
                  <div>
                    <p class="text-sm font-semibold text-on-surface">{artisan.name}</p>
                    <p class="text-xs uppercase tracking-[0.14em] text-on-surface-variant">{artisan.role}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {secondaryImage && (
        <div class="stitched-frame">
          <img
            src={secondaryImage.src}
            alt={secondaryImage.alt}
            class="aspect-[16/11] h-full w-full object-cover"
            loading="lazy"
            data-product-id={product.data.id}
            data-product-slug={product.slug}
            data-image-slot={String(secondaryImage.slot)}
          />
        </div>
      )}
    </section>

    <ValuesBento archiveImage={archiveImage?.src} />
  </main>

  <SiteFooter />
</BaseLayout>
