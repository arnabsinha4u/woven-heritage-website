---
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">;
  variant?: "stacked" | "compact";
}

const { product, variant = "stacked" } = Astro.props;
const featured = variant === "stacked";
---

<article
  class:list={[
    featured ? "paper-panel p-5 sm:p-6" : "soft-panel p-5",
    "group overflow-hidden transition-transform duration-300 hover:-translate-y-1"
  ]}
  data-product-id={product.data.id}
  data-product-slug={product.slug}
  data-collection-name={product.data.list_name}
>
  <a
    href={`/products/${product.slug}/`}
    class="block focus:outline-none focus:ring-2 focus:ring-primary/30 focus:ring-offset-4 focus:ring-offset-background"
    aria-label={`View ${product.data.title}`}
  >
    <div class:list={[featured ? "aspect-[1/1.02]" : "aspect-square", "overflow-hidden rounded-[1.8rem] bg-surface-low"]}>
      <img
        src={product.data.hero_image}
        alt={product.data.alt}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        data-product-id={product.data.id}
        data-product-slug={product.slug}
        data-image-slot="1"
        data-collection-name={product.data.list_name}
      />
    </div>

    <div class="mt-5 flex items-start justify-between gap-4">
      <div class="space-y-2">
        <h3 class="font-headline text-2xl leading-tight text-on-surface">{product.data.title}</h3>
        <p class="text-sm leading-6 text-on-surface-variant">{product.data.subtitle}</p>
      </div>

      <span class="rounded-full bg-secondary-container/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-on-secondary-container">
        {product.data.price_label}
      </span>
    </div>

    <p class="mt-4 text-sm leading-6 text-on-surface-variant">{product.data.summary}</p>

    <div class="mt-5 flex items-center justify-between gap-4">
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">View Piece</span>
      <span aria-hidden="true" class="text-lg text-primary transition-transform duration-300 group-hover:translate-x-1">→</span>
    </div>
  </a>
</article>
