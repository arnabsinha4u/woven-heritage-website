---
import { valuesContent } from "../data/site";

interface Props {
  archiveImage?: string;
}

const { archiveImage } = Astro.props;
---

<section class="mt-20 grid gap-5 md:grid-cols-3">
  <article class="soft-panel p-8">
    <p class="section-kicker">Value 01</p>
    <h3 class="mt-10 font-headline text-2xl text-on-surface">{valuesContent[0].title}</h3>
    <p class="mt-3 text-sm leading-6 text-on-surface-variant">{valuesContent[0].description}</p>
  </article>

  <article class="rounded-lounge bg-primary-wash p-8 text-on-primary shadow-float md:row-span-2">
    <p class="section-kicker text-white/70">Value 02</p>
    <h3 class="mt-20 font-headline text-4xl leading-tight">{valuesContent[1].title}</h3>
    <p class="mt-4 max-w-sm text-sm leading-7 text-white/85">{valuesContent[1].description}</p>
  </article>

  <article class="paper-panel p-8">
    <p class="section-kicker">Value 03</p>
    <h3 class="mt-10 font-headline text-2xl text-on-surface">{valuesContent[2].title}</h3>
    <p class="mt-3 text-sm leading-6 text-on-surface-variant">{valuesContent[2].description}</p>
  </article>

  <article class="relative overflow-hidden rounded-lounge bg-surface-high p-8">
    {archiveImage && (
      <img
        src={archiveImage}
        alt={valuesContent[3].description}
        class="absolute inset-0 h-full w-full object-cover opacity-20"
        loading="lazy"
        data-image-slot="archive"
      />
    )}
    <div class="relative">
      <p class="section-kicker">Value 04</p>
      <h3 class="mt-10 font-headline text-2xl text-on-surface">{valuesContent[3].title}</h3>
      <p class="mt-3 text-sm leading-6 text-on-surface-variant">{valuesContent[3].description}</p>
    </div>
  </article>

  <article class="paper-panel flex items-center justify-center p-8 text-center">
    <p class="font-headline text-xl italic leading-8 text-primary">“Truly handmade never follows a grid.”</p>
  </article>
</section>
